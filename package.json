{
  "name": "notificationapi-react-native-sdk",
  "version": "1.0.0",
  "description": "React Native SDK for NotificationAPI - Push notifications for Android and iOS",
  "main": "js/index.ts",
  "types": "js/index.ts",
  "react-native": "js/index",
  "source": "js/index",
  "repository": {
    "type": "git",
    "url": "https://github.com/notificationapi-com/notificationapi-react-native-sdk.git"
  },
  "keywords": [
    "react-native",
    "notificationapi",
    "push-notifications",
    "notifications",
    "fcm",
    "apn"
  ],
  "author": "NotificationAPI",
  "license": "MIT",
  "homepage": "https://www.notificationapi.com",
  "files": [
    "js",
    "android",
    "ios",
    "rtn-notificationapi.podspec",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint js --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "react": "*",
    "react-native": "*",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "resolutions": {
    "ws": "^7.5.10"
  },
  "codegenConfig": {
    "name": "NotificationApiReactNativeSdkSpec",
    "type": "modules",
    "jsSrcsDir": "js",
    "android": {
      "javaPackageName": "com.notificationapi.rn"
    }
  }
}
